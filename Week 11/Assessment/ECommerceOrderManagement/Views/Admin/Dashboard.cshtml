@model ECommerceOrderManagement.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";

    // Correct Counts

    var pendingCount =
        Model.PendingOrders?.Count() ?? 0;

    var shippedCount =
        Model.ShippedOrders?.Count() ?? 0;

    var deliveredCount =
        Model.DeliveredOrders?.Count() ?? 0;
}

<style>

/* Background */

body {
    background: linear-gradient(
        135deg,
        #eef2f7,
        #f9fbfd
    );
}

/* Dashboard Title */

.dashboard-title {

    font-weight: 700;

    font-size: 28px;

    background: linear-gradient(
        90deg,
        #0d6efd,
        #6f42c1
    );

    -webkit-background-clip: text;

    -webkit-text-fill-color: transparent;
}

/* Cards */

.dashboard-card {

    border: none;

    border-radius: 18px;

    background: linear-gradient(
        145deg,
        #ffffff,
        #f1f3f6
    );

    box-shadow:
        0 8px 20px rgba(0,0,0,0.08);

    transition: 0.3s;
}

.dashboard-card:hover {

    transform: translateY(-6px);

}

/* Stat Cards */

.stat-card {

    border-radius: 18px;

    padding: 20px;

    box-shadow:
        0 10px 25px rgba(0,0,0,0.08);

}

</style>

<div class="container-fluid mt-4">

<!-- HEADER -->

<div class="d-flex justify-content-between align-items-center mb-4">

<h2 class="dashboard-title">
🚀 Shipping Dashboard
</h2>

</div>

<!-- SUMMARY CARDS -->

<div class="row mb-4">

<div class="col-md-3 mb-3">

<div class="stat-card bg-warning text-dark text-center">

<h6>📦 Pending</h6>

<h3>@pendingCount</h3>

</div>

</div>

<div class="col-md-3 mb-3">

<div class="stat-card bg-info text-white text-center">

<h6>🚚 Shipped</h6>

<h3>@shippedCount</h3>

</div>

</div>

<div class="col-md-3 mb-3">

<div class="stat-card bg-success text-white text-center">

<h6>✅ Delivered</h6>

<h3>@deliveredCount</h3>

</div>

</div>

<div class="col-md-3 mb-3">

<div class="stat-card bg-dark text-white text-center">

<h6>📊 Total Orders</h6>

<h3>@Model.TotalOrders</h3>

</div>

</div>

</div>

<!-- TOP PRODUCTS -->

<h4 class="mb-3">
🔥 Top Selling Products
</h4>

<div class="row mb-5">

@if (Model.TopProducts != null &&
    Model.TopProducts.Any())
{

@foreach (var product in Model.TopProducts)
{
<div class="col-md-3 mb-3">

<div class="card dashboard-card text-center">

<div class="card-body">

<h6 class="fw-bold">

@product.ProductName

</h6>

</div>

</div>

</div>
}

}
else
{

<div class="col-12">

<div class="alert alert-warning">

⚠ No top products available.

</div>

</div>

}

</div>

<!-- PENDING ORDERS -->

<h4 class="mb-3">
📦 Pending Orders
</h4>

@if (Model.PendingOrders != null &&
    Model.PendingOrders.Any())
{

<div class="row g-4">

@foreach (var order in Model.PendingOrders)
{

<div class="col-md-6 col-xl-4">

<div class="card dashboard-card h-100">

<div class="card-body">

<div class="d-flex justify-content-between">

<h5 class="fw-bold text-primary">

#@order.OrderId

</h5>

<span class="badge bg-warning text-dark">

⏳ Pending

</span>

</div>

<div class="mt-2">

👤 @order.Customer?.Name

</div>

<div class="d-flex gap-2 mt-3">

<a asp-action="UpdateShippingStatus"
   asp-route-id="@order.ShippingDetail.ShippingDetailId"
   asp-route-status="Shipped"
   class="btn btn-warning btn-sm flex-fill">

🚚 Ship

</a>

<a asp-action="UpdateShippingStatus"
   asp-route-id="@order.ShippingDetail.ShippingDetailId"
   asp-route-status="Delivered"
   class="btn btn-success btn-sm flex-fill">

✅ Deliver

</a>

</div>

</div>

</div>

</div>

}

</div>

}
else
{

<div class="alert alert-info">

📭 No pending orders.

</div>

}

<!-- SHIPPED ORDERS -->

<h4 class="mt-5 mb-3">
🚚 Shipped Orders
</h4>

@if (Model.ShippedOrders != null &&
    Model.ShippedOrders.Any())
{

<div class="row g-4">

@foreach (var order in Model.ShippedOrders)
{

<div class="col-md-6 col-xl-4">

<div class="card dashboard-card">

<div class="card-body">

<h5 class="fw-bold text-primary">

#@order.OrderId

</h5>

<div>

👤 @order.Customer?.Name

</div>

<span class="badge bg-info mt-2">

🚚 Shipped

</span>

</div>

</div>

</div>

}

</div>

}
else
{

<div class="alert alert-info">

📭 No shipped orders.

</div>

}

<!-- DELIVERED ORDERS -->

<h4 class="mt-5 mb-3">
✅ Delivered Orders
</h4>

@if (Model.DeliveredOrders != null &&
    Model.DeliveredOrders.Any())
{

<div class="row g-4">

@foreach (var order in Model.DeliveredOrders)
{

<div class="col-md-6 col-xl-4">

<div class="card dashboard-card">

<div class="card-body">

<h5 class="fw-bold text-primary">

#@order.OrderId

</h5>

<div>

👤 @order.Customer?.Name

</div>

<span class="badge bg-success mt-2">

✅ Delivered

</span>

</div>

</div>

</div>

}

</div>

}
else
{

<div class="alert alert-success">

📭 No delivered orders.

</div>

}

</div>