@model ECommerceOrderManagement.Models.Customer

@{
    ViewData["Title"] = "Create Customer";
}

<div class="container mt-4">

    <!-- Page Header -->

    <div class="text-center mb-4">

        <h2 class="fw-bold">
            👤 Create New Customer
        </h2>

        <p class="text-muted">
            Add customer details to the system
        </p>

    </div>

    <!-- Form Card -->

    <div class="row justify-content-center">

        <div class="col-md-6 col-lg-5">

            <div class="card shadow">

                <div class="card-body">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <!-- Customer Name -->

                        <div class="mb-3">

                            <label asp-for="Name"
                                   class="form-label fw-semibold">

                                👤 Customer Name

                            </label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Enter customer name" />

                            <span asp-validation-for="Name"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Email -->

                        <div class="mb-3">

                            <label asp-for="Email"
                                   class="form-label fw-semibold">

                                📧 Email Address

                            </label>

                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="Enter email address" />

                            <span asp-validation-for="Email"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Phone -->

                        <div class="mb-3">

                            <label asp-for="Phone"
                                   class="form-label fw-semibold">

                                📞 Phone Number

                            </label>

                            <input asp-for="Phone"
                                   class="form-control"
                                   placeholder="Enter phone number" />

                            <span asp-validation-for="Phone"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Buttons -->

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                ⬅ Back to List

                            </a>

                            <button type="submit"
                                    class="btn btn-success">

                                ➕ Create Customer

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}