@model ECommerceOrderManagement.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<div class="container mt-4">

    <!-- Page Header -->

    <div class="text-center mb-4">

        <h2 class="fw-bold">
            ➕ Create New Product
        </h2>

        <p class="text-muted">
            Add a new product to the store inventory
        </p>

    </div>

    <!-- Form Card -->

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">

                <div class="card-body">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <!-- Product Name -->

                        <div class="mb-3">

                            <label asp-for="ProductName"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="ProductName"
                                   class="form-control"
                                   placeholder="Enter product name" />

                            <span asp-validation-for="ProductName"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Price -->

                        <div class="mb-3">

                            <label asp-for="Price"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Price"
                                   class="form-control"
                                   placeholder="Enter price" />

                            <span asp-validation-for="Price"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Stock -->

                        <div class="mb-3">

                            <label asp-for="Stock"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Stock"
                                   class="form-control"
                                   placeholder="Enter stock quantity" />

                            <span asp-validation-for="Stock"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Category -->

                        <div class="mb-3">

                            <label asp-for="CategoryId"
                                   class="form-label fw-semibold">
                            </label>

                            <select asp-for="CategoryId"
                                    class="form-select"
                                    asp-items="ViewBag.CategoryId">

                                <option value="">
                                    -- Select Category --
                                </option>

                            </select>

                        </div>

                        <!-- Buttons -->

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                ⬅ Back to List

                            </a>

                            <button type="submit"
                                    class="btn btn-primary">

                                ➕ Create Product

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}