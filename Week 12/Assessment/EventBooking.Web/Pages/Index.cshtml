@page
@model IndexModel

<style>
    .hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 100px 0;
    }

    .feature-card {
        transition: all 0.3s ease;
        border: none;
        border-radius: 0.75rem;
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.18);
    }

    .feature-card .card-body {
        text-align: center;
        padding: 2rem;
    }

    .feature-icon {
        font-size: 2.5rem;
        color: #667eea;
        margin-bottom: 1rem;
    }

    .cta-button {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 0.5rem;
        transition: transform 0.2s ease;
    }

    .cta-button:hover {
        transform: scale(1.05);
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .event-preview {
        background: #f8f9fa;
        padding: 60px 0;
    }

    .stats-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 0;
    }

    .stat-item h3 {
        font-size: 2.5rem;
        font-weight: bold;
    }
</style>

<!-- Hero Section -->
<div class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-4 fw-bold mb-4">
                    <i class="bi bi-calendar-event"></i> Discover Amazing Events
                </h1>
                <p class="lead mb-4">
                    Find, book, and enjoy the best events in your city. From concerts to conferences, we have it all.
                </p>
                <div class="d-flex gap-3">
                    <a asp-page="/Events" class="btn cta-button btn-lg text-white">
                        <i class="bi bi-search"></i> Browse Events
                    </a>
                    <a asp-page="/Register" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-person-plus"></i> Join Now
                    </a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="text-center">
                    <i class="bi bi-calendar-event" style="font-size: 15rem; opacity: 0.8;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container my-5">
    <div class="text-center mb-5">
        <h2 class="display-6 fw-bold mb-3">Why Choose EventBooking?</h2>
        <p class="text-muted lead">Everything you need for a seamless event booking experience</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card feature-card shadow-sm">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-search"></i>
                    </div>
                    <h5 class="card-title fw-bold">Easy Discovery</h5>
                    <p class="card-text text-muted">
                        Browse thousands of events across different categories and find exactly what you're looking for.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card feature-card shadow-sm">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 class="card-title fw-bold">Secure Booking</h5>
                    <p class="card-text text-muted">
                        Your personal information and payments are protected with industry-leading security.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card feature-card shadow-sm">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-bell"></i>
                    </div>
                    <h5 class="card-title fw-bold">Instant Notifications</h5>
                    <p class="card-text text-muted">
                        Get real-time updates about your bookings and never miss an important event detail.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="stats-section">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 stat-item py-4">
                <h3>5,000+</h3>
                <p class="lead mb-0">Active Events</p>
            </div>
            <div class="col-md-4 stat-item py-4 border-start border-end border-white">
                <h3>50,000+</h3>
                <p class="lead mb-0">Happy Users</p>
            </div>
            <div class="col-md-4 stat-item py-4">
                <h3>100+</h3>
                <p class="lead mb-0">Cities Covered</p>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="event-preview">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h2 class="fw-bold mb-4">Ready to Book Your First Event?</h2>
                <p class="text-muted lead mb-4">
                    Join thousands of people who are already enjoying amazing events with EventBooking.
                </p>
                <ul class="list-unstyled">
                    <li class="mb-3">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Browse unlimited events</strong>
                    </li>
                    <li class="mb-3">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Quick and easy booking</strong>
                    </li>
                    <li class="mb-3">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>24/7 customer support</strong>
                    </li>
                    <li class="mb-3">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Secure payment options</strong>
                    </li>
                </ul>
                <a asp-page="/Register" class="btn cta-button btn-lg text-white mt-3">
                    <i class="bi bi-arrow-right"></i> Get Started Today
                </a>
            </div>
            <div class="col-md-6">
                <div class="text-center">
                    <i class="bi bi-ticket-perforated" style="font-size: 12rem; color: #667eea; opacity: 0.7;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="bg-dark text-white py-5 mt-5">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-calendar-event"></i> EventBooking
                </h5>
                <p class="text-muted">Your ultimate destination for discovering and booking amazing events.</p>
            </div>
            <div class="col-md-4 mb-4">
                <h6 class="fw-bold">Quick Links</h6>
                <ul class="list-unstyled">
                    <li><a asp-page="/Events" class="text-muted text-decoration-none">Browse Events</a></li>
                    <li><a asp-page="/MyBookings" class="text-muted text-decoration-none">My Bookings</a></li>
                    <li><a asp-page="/Privacy" class="text-muted text-decoration-none">Privacy Policy</a></li>
                </ul>
            </div>
            <div class="col-md-4 mb-4">
                <h6 class="fw-bold">Contact Us</h6>
                <p class="text-muted">
                    <i class="bi bi-envelope"></i> support@eventbooking.com<br>
                    <i class="bi bi-telephone"></i> +1 (555) 123-4567
                </p>
            </div>
        </div>
        <hr class="bg-secondary">
        <p class="text-center text-muted mb-0">&copy; 2026 EventBooking. All rights reserved.</p>
    </div>
</footer>