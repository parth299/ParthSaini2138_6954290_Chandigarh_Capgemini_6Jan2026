@page
@model EventBooking.Web.Pages.LoginModel

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-key-fill"></i> Login
                    </h3>
                </div>
                <div class="card-body p-5">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle"></i>
                            @Model.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Login.Username" class="form-label fw-bold">
                                <i class="bi bi-person"></i> Username
                            </label>
                            <input type="text" class="form-control form-control-lg" 
                                   asp-for="Login.Username" 
                                   placeholder="Enter your username" required>
                            <span asp-validation-for="Login.Username" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Login.Password" class="form-label fw-bold">
                                <i class="bi bi-lock-fill"></i> Password
                            </label>
                            <input type="password" class="form-control form-control-lg" 
                                   asp-for="Login.Password" 
                                   placeholder="Enter your password" required>
                            <span asp-validation-for="Login.Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                            <i class="bi bi-check-circle"></i> Login
                        </button>
                    </form>

                    <hr class="my-4">

                    <p class="text-center text-muted mb-0">
                        Don't have an account? 
                        <a asp-page="/Register" class="text-decoration-none fw-bold">Register here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 0.5rem;
        margin-top: 2rem;
    }

    .card-header {
        border-radius: 0.5rem 0.5rem 0 0;
        padding: 1.5rem;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(13, 110, 253, 0.3);
    }
</style>