@page
@model EventBooking.Web.Pages.MyBookingsModel

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold">
                <i class="bi bi-calendar-check"></i> My Bookings
            </h1>
            <p class="text-muted">Manage and view all your event bookings</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="/Events" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle"></i> Book New Event
            </a>
        </div>
    </div>

    @if (Model.Bookings == null || Model.Bookings.Count == 0)
    {
        <div class="row">
            <div class="col-md-8 mx-auto">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-5">
                        <div class="mb-3">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #6c757d;"></i>
                        </div>
                        <h4 class="card-title text-muted">No Bookings Yet</h4>
                        <p class="card-text text-muted mb-4">
                            You haven't booked any events. Start exploring our events and book your favorite ones!
                        </p>
                        <a asp-page="/Events" class="btn btn-primary btn-lg">
                            <i class="bi bi-search"></i> Browse Events
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var b in Model.Bookings)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100 border-0 transition-all">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-calendar-event"></i> @b.EventTitle
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <p class="mb-2">
                                    <strong><i class="bi bi-calendar-date"></i> Date:</strong>
                                    <span class="badge bg-info">@b.EventDate.ToShortDateString()</span>
                                </p>
                                <p class="mb-2">
                                    <strong><i class="bi bi-geo-alt"></i> Location:</strong>
                                    <span class="text-dark">@b.Location</span>
                                </p>
                                <p class="mb-2">
                                    <strong><i class="bi bi-chair"></i> Seats Booked:</strong>
                                    <span class="badge bg-success">@b.SeatsBooked</span>
                                </p>
                                <p class="mb-0">
                                    <strong><i class="bi bi-cash-coin"></i> Booking ID:</strong>
                                    <span class="text-muted">#@b.BookingId</span>
                                </p>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-top">
                            <form method="post" asp-page-handler="Cancel" class="d-inline">
                                <input type="hidden" name="id" value="@b.BookingId" />
                                <button type="submit" class="btn btn-danger btn-sm w-100" 
                                        onclick="return confirm('Are you sure you want to cancel this booking?');">
                                    <i class="bi bi-trash"></i> Cancel Booking
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-all {
        transition: all 0.3s ease-in-out;
    }

    .transition-all:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.18) !important;
    }

    .card-header {
        border-radius: 0.25rem 0.25rem 0 0;
    }

    .badge {
        font-size: 0.85rem;
        padding: 0.5rem 0.75rem;
    }
</style>