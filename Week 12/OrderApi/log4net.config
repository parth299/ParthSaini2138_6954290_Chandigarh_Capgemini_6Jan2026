<log4net>

  <!-- File Log -->

  <appender name="RollingFileAppender"
            type="log4net.Appender.RollingFileAppender">

    <file value="logs/app.log"/>

    <appendToFile value="true"/>

    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern
        value="%date %-5level %logger - %message%newline"/>
    </layout>

  </appender>


  <!-- Database Log -->

  <appender name="AdoNetAppender"
            type="log4net.Appender.AdoNetAppender">

    <connectionType
     value="System.Data.SqlClient.SqlConnection, System.Data"/>

    <connectionString
     value="Server=.;Database=OrderDb;Trusted_Connection=True;"/>

    <commandText
     value="INSERT INTO Logs(Date,Level,Logger,Message)
            VALUES(@log_date,@log_level,@logger,@message)"/>

  </appender>


  <root>

    <level value="ALL"/>

    <appender-ref ref="RollingFileAppender"/>
    <appender-ref ref="AdoNetAppender"/>

  </root>

</log4net>